# 1Password references for Pulumi — safe to commit (no actual secrets here).
# Usage: op run --env-file=.pulumi.env -- pulumi <command>
#
# Set up:
#   op item create --category=password \
#     --title="ocs-automation pulumi" \
#     --vault=Private \
#     password=<your-passphrase>
#
# Then update the reference below to match your vault/item names.
PULUMI_CONFIG_PASSPHRASE=op://Private/ocs-automation pulumi/password
