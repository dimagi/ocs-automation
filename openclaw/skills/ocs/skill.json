{
  "name": "ocs",
  "version": "1.0.0",
  "description": "OpenClaw skill for open-chat-studio automation",
  "triggers": [
    {
      "type": "slack-mention",
      "pattern": "work on #(\\d+)",
      "action": "work-on-issue",
      "capture": "issue_number"
    },
    {
      "type": "slack-mention",
      "pattern": "review #(\\d+)",
      "action": "pr-review",
      "capture": "issue_number"
    },
    {
      "type": "slack-command",
      "command": "/ocs",
      "action": "ad-hoc"
    },
    {
      "type": "github-webhook",
      "event": "pull_request",
      "actions": ["opened", "synchronize"],
      "action": "pr-review"
    },
    {
      "type": "github-webhook",
      "event": "workflow_run",
      "conclusion": "failure",
      "action": "ci-triage"
    },
    {
      "type": "cron",
      "schedule": "0 6 * * 1-5",
      "action": "scheduled-typecheck",
      "description": "Weekday 6am — incremental type checking progress"
    }
  ],
  "session": {
    "manager": "./session-manager.sh",
    "lock_file": "/data/sessions/.lock",
    "timeout_minutes": 60
  }
}
