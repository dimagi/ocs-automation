# openclaw/.env.example
# Copy to .env.prod and fill in values — never commit .env.prod
# Push to Secrets Manager: uv run inv push-secrets --env-file=.env.prod

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI (used for memory search embeddings)
OPENAI_API_KEY=

# GitHub
GITHUB_TOKEN=ghp_...

# GitHub App (for webhook signature verification)
GITHUB_WEBHOOK_SECRET=

# Slack App (Socket Mode — outbound WebSocket, no public URL needed)
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...

# Slack exec-approval approvers (comma-separated Slack user IDs, e.g. U0123ABCD,U0456EFGH).
# Consumed by scripts/patch-slack-policy.sh — when set, deploy patches
# channels.slack.execApprovals so risky tool calls require explicit DM approval.
SLACK_APPROVERS=

# Domain (must match: pulumi config set domain <value>)
DOMAIN=agent.openchatstudio.com
